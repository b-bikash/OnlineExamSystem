@model object

@{
    ViewData["Title"] = "Dashboard";

    var role = Context.Session.GetString("Role");

    var fullName = Context.Session.GetString("FullName");
    var username = Context.Session.GetString("Username");

    var displayName = !string.IsNullOrWhiteSpace(fullName)
        ? fullName
        : username;
}

<div class="mt-4">
    <h2 class="mb-3">Dashboard</h2>

    <p class="text-muted">
        Welcome, <strong>@displayName</strong>
    </p>

    <div class="row mt-4">

        @* ================= ADMIN ================= *@
        @if (role == "Admin" || role == "TeacherAdmin")
        {
            @* ================= ADMIN ANALYTICS================= *@
            @if (role == "Admin")
            {
                var stats = Model as OnlineExamSystem.Models.ViewModels.AdminDashboardViewModel;

                if (stats != null)
                {
                    <div class="row mb-4">

                        <div class="col-md-3 mb-3">
                            <div class="card text-white bg-dark shadow-sm">
                                <div class="card-body">
                                    <h6>Total Colleges</h6>
                                    <h3>@stats.TotalColleges</h3>
                                    <small>Active: @stats.ActiveColleges</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="card text-white bg-primary shadow-sm">
                                <div class="card-body">
                                    <h6>Total Users</h6>
                                    <h3>@stats.TotalUsers</h3>
                                    <small>
                                        Students: @stats.TotalStudents |
                                        Teachers: @stats.TotalTeachers
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="card text-white bg-success shadow-sm">
                                <div class="card-body">
                                    <h6>Total Exams</h6>
                                    <h3>@stats.TotalExams</h3>
                                    <small>
                                        Live: @stats.LiveExams |
                                        Upcoming: @stats.UpcomingExams |
                                        Completed: @stats.PastExams
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="card text-white bg-info shadow-sm">
                                <div class="card-body">
                                    <h6>Courses</h6>
                                    <h3>@stats.TotalCourses</h3>
                                    <small>
                                        Subjects: @stats.TotalSubjects
                                    </small>
                                </div>
                            </div>
                        </div>

                    </div>
                }
            }
    
            @* ================= TEACHERADMIN ANALYTICS================= *@
            @if (role == "TeacherAdmin")
            {
                var stats = Model as OnlineExamSystem.ViewModels.TeacherAdminDashboardViewModel;

                if (stats != null)
                {
                    <div class="row mb-4">

                        <div class="col-md-3 mb-3">
                            <div class="card text-white bg-primary shadow-sm">
                                <div class="card-body">
                                    <h6>Total Students</h6>
                                    <h3>@stats.TotalStudents</h3>
                                    <small>Teachers: @stats.TotalTeachers</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="card text-white bg-success shadow-sm">
                                <div class="card-body">
                                    <h6>Total Exams</h6>
                                    <h3>@stats.TotalExams</h3>
                                    <small>
                                        Live: @stats.LiveExamsCount |
                                        Upcoming: @stats.UpcomingExamsCount |
                                        Completed: @stats.CompletedExamsCount
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="card text-white bg-info shadow-sm">
                                <div class="card-body">
                                    <h6>Courses</h6>
                                    <h3>@stats.TotalCourses</h3>
                                    <small>Subjects: @stats.TotalSubjects</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3 mb-3">
                            <div class="card text-white bg-dark shadow-sm">
                                <div class="card-body">
                                    <h6>Total Exam Attempts</h6>
                                    <h3>@stats.TotalExamAttempts</h3>
                                    @if (stats.AverageScore.HasValue)
                                    {
                                        <small>Avg Score: @stats.AverageScore.Value.ToString("0.00")</small>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                }
            }
            @if (role == "Admin")
            {
                <!-- User Management -->
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">User Management</h5>
                            <p class="card-text text-muted">Create, edit and manage users.</p>
                            <div class="mt-auto">
                                <a asp-controller="Users" asp-action="Index"
                                class="btn btn-primary btn-sm">
                                    Manage Users
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
            <!-- Student Management -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">Student Management</h5>
                        <p class="card-text text-muted">View and correct student details.</p>
                        <div class="mt-auto">
                            <a asp-controller="AdminStudents" asp-action="Index"
                               class="btn btn-secondary btn-sm">
                                Manage Students
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Teacher Management -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">Teacher Management</h5>
                        <p class="card-text text-muted">View, add, and manage teachers.</p>
                        <div class="mt-auto">
                            <a asp-controller="AdminTeachers" asp-action="Index"
                               class="btn btn-warning btn-sm">
                                Manage Teachers
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Course Management -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">Course Management</h5>
                        <p class="card-text text-muted">View and manage courses.</p>
                        <div class="mt-auto">
                            <a asp-controller="AdminCourses" asp-action="Index"
                               class="btn btn-info btn-sm">
                                Manage Courses
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Subject Management -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">Subject Management</h5>
                        <p class="card-text text-muted">Create and manage academic subjects.</p>
                        <div class="mt-auto">
                            <a asp-controller="AdminSubjects" asp-action="Index"
                               class="btn btn-info btn-sm">
                                Manage Subjects
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            @if (role == "Admin")
            {
                <!-- College Management -->
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">College Management</h5>
                            <p class="card-text text-muted">View and manage colleges.</p>
                            <div class="mt-auto">
                                <a asp-controller="AdminColleges" asp-action="Index"
                                class="btn btn-dark btn-sm">
                                    Manage Colleges
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
            <!-- Exam Management -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">Exam Management</h5>
                        <p class="card-text text-muted">View and manage all exams.</p>
                        <div class="mt-auto">
                            <a asp-controller="Exams" asp-action="Index"
                               class="btn btn-success btn-sm">
                                Manage Exams
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Import / Export Management -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">Import / Export</h5>
                        <p class="card-text text-muted">
                            Bulk import courses & subjects or export existing data.
                        </p>
                        <div class="mt-auto">
                            <a asp-controller="TeacherAdminImport"
                               asp-action="Index"
                               class="btn btn-outline-primary btn-sm">
                                Manage Import / Export
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ================= TEACHER ================= *@
        @if (role == "Teacher")
        {
            var teacher = Model as OnlineExamSystem.Models.Teacher;

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title">Exam Management</h5>
                        <p class="card-text text-muted">Create exams and add questions.</p>
                        <a asp-controller="Exams" asp-action="Index"
                           class="btn btn-success btn-sm">
                            View Exams
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title">My Profile</h5>
                        <p class="card-text text-muted">Update your personal details.</p>
                        <a asp-controller="Teachers" asp-action="Profile"
                           class="btn btn-warning btn-sm">
                            Edit Profile
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title">My Subjects</h5>
                        <p class="text-muted mb-2">
                            Subjects assigned to you by admin.
                        </p>

                        @if (teacher != null && teacher.TeacherSubjects != null && teacher.TeacherSubjects.Any())
                        {
                            <ul class="mb-0">
                                @foreach (var ts in teacher.TeacherSubjects)
                                {
                                    <li>@ts.Subject.Name (@ts.Subject.Code)</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">
                                No subjects assigned yet.
                            </span>
                        }
                    </div>
                </div>
            </div>
        }

        @* ================= STUDENT ================= *@
        @if (role == "Student")
        {
            var student = ViewBag.Student as OnlineExamSystem.Models.Student;

            if (student != null && !student.IsProfileCompleted)
            {
                <div class="alert alert-warning">
                    <strong>Welcome!</strong><br />
                    Please complete your profile to start attempting exams.
                    <br />
                    <a asp-controller="Students" asp-action="Profile" class="alert-link">
                        Complete Profile
                    </a>
                </div>
            }

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title">Available Exams</h5>
                        <p class="card-text text-muted">Attempt available exams.</p>
                        <a asp-controller="Exams" asp-action="Index"
                           class="btn btn-warning btn-sm">
                            View Exams
                        </a>
                    </div>
                </div>
            </div>
        }

    </div>
</div>
