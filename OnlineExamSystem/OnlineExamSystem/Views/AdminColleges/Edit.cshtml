@model OnlineExamSystem.Models.College

@{
    ViewData["Title"] = "Edit College";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 500px; border-radius: 12px;">
        <div class="card-body p-4">

            <h3 class="text-center mb-3">Edit College</h3>
            <p class="text-center text-muted mb-4">Update college details</p>

            <form asp-action="Edit" method="post">

                <!-- HIDDEN -->
                <input type="hidden" asp-for="Id" />

                <!-- VALIDATION -->
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- COLLEGE NAME -->
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Enter college name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Save Changes
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}