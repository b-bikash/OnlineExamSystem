@model List<OnlineExamSystem.Models.College>

@{
    ViewData["Title"] = "College Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">College Management</h2>

    <!-- Demo Data Button -->
    <form asp-controller="Demo" asp-action="Generate" method="post">
        <button type="submit"
                class="btn btn-primary"
                onclick="return confirm('Generate demo data? This may take a few seconds.');">
            Generate Demo Data
        </button>
    </form>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="d-flex mb-3" style="max-width: 400px;">
    <input type="text"
           name="search"
           value="@ViewBag.Search"
           class="form-control me-2"
           placeholder="Search by college name" />
    <button type="submit" class="btn btn-outline-secondary">
        Search
    </button>
</form>

<a asp-action="Create" class="btn btn-success mb-3">
    + Add College
</a>

<!-- Hard Delete Instruction Box -->
<div class="alert alert-warning mt-3">
    <strong>⚠️ Important:</strong>
    To permanently delete all data of a college, type <strong>"DELETE"</strong> in the input box provided and click on <strong>Hard Delete</strong>.
    <br />
    <span class="text-danger">
        This action is irreversible and will remove all associated data including students, teachers, exams, and results.
    </span>
</div>

@if (Model.Any())
{
    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var college in Model)
            {
                <tr>
                    <td>@college.Name</td>
                    <td>
                        @if (college.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-2 flex-wrap">

                            <!-- Edit -->
                            <a asp-action="Edit"
                                   asp-route-id="@college.Id"
                                   class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <!-- Enable / Disable -->
                            <a asp-action="ToggleStatus"
                                   asp-route-id="@college.Id"
                                   class="btn btn-sm btn-secondary">
                                @(college.IsActive ? "Disable" : "Enable")
                            </a>

                            <!-- Soft Delete -->
                            <a asp-action="Delete"
                                   asp-route-id="@college.Id"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Are you sure you want to delete this college?');">
                                Delete
                            </a>

                            <!-- HARD DELETE -->
                            <form asp-action="HardDelete" method="post" class="d-flex gap-1">
                                <input type="hidden" name="id" value="@college.Id" />

                                <input type="text"
                                       name="confirmText"
                                       placeholder="DELETE"
                                       class="form-control form-control-sm confirm-input"
                                       style="width:100px;" />

                                <button type="submit"
                                        class="btn btn-sm btn-dark hard-delete-btn"
                                        disabled
                                        onclick="return confirm('⚠️ This will permanently delete ALL data of this college. Continue?');">
                                    Hard Delete
                                </button>
                            </form>

                            </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="border rounded p-4 text-center text-muted mt-4">
        <h5>No colleges found</h5>
        <p class="mb-0">
            Try searching by name or add a new college.
        </p>
    </div>
}

<script>
    document.querySelectorAll('.confirm-input').forEach(function (input) {
        input.addEventListener('input', function () {
            var form = input.closest('form');
            var button = form.querySelector('.hard-delete-btn');

            if (input.value === "DELETE") {
                button.disabled = false;
            } else {
                button.disabled = true;
            }
        });
    });

    // Prevent multiple submissions
    document.querySelectorAll('form').forEach(function (form) {
        form.addEventListener('submit', function () {
            var button = form.querySelector('.hard-delete-btn');
            if (button) {
                button.disabled = true;
                button.innerText = "Deleting...";
            }
        });
    });
</script>