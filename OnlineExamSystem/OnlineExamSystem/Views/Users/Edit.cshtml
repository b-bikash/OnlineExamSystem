@model OnlineExamSystem.Models.User

@{
    ViewData["Title"] = "Edit User";
    var fullName = ViewBag.FullName as string;
    var colleges = ViewBag.Colleges as List<OnlineExamSystem.Models.College>;
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 500px; border-radius: 12px;">
        <div class="card-body p-4">

            <h3 class="text-center mb-3">Edit User</h3>
            <p class="text-center text-muted mb-4">Update user details</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form method="post">

                <input type="hidden" name="id" value="@Model.Id" />

                <!-- ROLE -->
                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <select name="Role" id="roleSelect" class="form-select" required>
                        <option value="Admin" selected="@(Model.Role == "Admin")">Admin</option>
                        <option value="TeacherAdmin" selected="@(Model.Role == "TeacherAdmin")">Teacher Admin</option>
                        <option value="Teacher" selected="@(Model.Role == "Teacher")">Teacher</option>
                        <option value="Student" selected="@(Model.Role == "Student")">Student</option>
                    </select>
                </div>

                <!-- COLLEGE -->
                <div class="mb-3">
                    <label class="form-label">College</label>
                    <select name="CollegeId" id="collegeSelect" class="form-select">
                        <option value="">Select College</option>
                        @if (colleges != null)
                        {
                            foreach (var college in colleges)
                            {
                                <option value="@college.Id"
                                        selected="@(Model.CollegeId == college.Id)">
                                    @college.Name
                                </option>
                            }
                        }
                    </select>
                    <span class="text-danger" id="collegeValidation" style="display:none;">
                        College is required for this role.
                    </span>
                </div>

                <!-- FULL NAME -->
                <div class="mb-3" id="fullNameWrapper">
                    <label class="form-label">Full Name</label>
                    <input name="FullName"
                           id="fullNameInput"
                           class="form-control"
                           value="@fullName"
                           placeholder="Enter full name" />
                </div>

                <!-- USERNAME (READ ONLY) -->
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input class="form-control" value="@Model.Username" disabled />
                </div>

                <!-- EMAIL -->
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input name="Email"
                           type="email"
                           class="form-control"
                           value="@Model.Email"
                           placeholder="Enter email"
                           required />
                </div>

                <!-- PASSWORD -->
                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <input name="Password"
                           type="password"
                           class="form-control"
                           placeholder="Leave blank to keep current password" />
                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const roleSelect = document.getElementById("roleSelect");
        const fullNameWrapper = document.getElementById("fullNameWrapper");
        const fullNameInput = document.getElementById("fullNameInput");
        const collegeSelect = document.getElementById("collegeSelect");
        const collegeValidation = document.getElementById("collegeValidation");

        function toggleFields() {

            const role = roleSelect.value;

            // FULL NAME
            if (role === "Admin") {
                fullNameWrapper.style.display = "none";
                fullNameInput.removeAttribute("required");
            } else {
                fullNameWrapper.style.display = "block";
                fullNameInput.setAttribute("required", "required");
            }

            // COLLEGE
            if (role === "Admin") {
                collegeSelect.value = "";
                collegeSelect.setAttribute("disabled", "disabled");
                collegeSelect.removeAttribute("required");
                collegeValidation.style.display = "none";
            } else {
                collegeSelect.removeAttribute("disabled");
                collegeSelect.setAttribute("required", "required");
            }
        }

        document.querySelector("form").addEventListener("submit", function (e) {
            const role = roleSelect.value;

            if (role !== "Admin" && !collegeSelect.value) {
                e.preventDefault();
                collegeValidation.style.display = "block";
            }
        });

        roleSelect.addEventListener("change", function () {
            collegeValidation.style.display = "none";
            toggleFields();
        });

        toggleFields();
    </script>
}