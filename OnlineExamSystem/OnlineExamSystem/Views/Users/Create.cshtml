@model OnlineExamSystem.Models.User

@{
    ViewData["Title"] = "Create User";
}

<h2 class="mb-4">Create New User</h2>

<div class="card shadow-sm border-0">
    <div class="card-body">

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form asp-controller="Users" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <!-- ROLE -->
            <div class="mb-3">
                <label class="form-label">Role</label>
                <select asp-for="Role" id="roleSelect" class="form-select" required>
                    <option value="">-- Select Role --</option>
                    <option value="Student">Student</option>
                    <option value="Teacher">Teacher</option>
                    <option value="TeacherAdmin">Teacher Admin</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>

            <!-- COLLEGE -->
            <div class="mb-3" id="collegeWrapper">
                <label class="form-label">College</label>
                <select asp-for="CollegeId"
                        id="collegeSelect"
                        class="form-select"
                        asp-items="@(new SelectList(ViewBag.Colleges, "Id", "Name"))">
                    <option value="">-- Select College --</option>
                </select>

                <span class="text-danger" id="collegeValidation" style="display:none;">
                    College is required for this role.
                </span>
            </div>

            <!-- FULL NAME -->
            <div class="mb-3" id="fullNameWrapper">
                <label class="form-label">Full Name</label>
                <input name="FullName"
                       id="fullNameInput"
                       class="form-control" />
            </div>

            <!-- USERNAME -->
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input asp-for="Username" class="form-control" required />
            </div>

            <!-- EMAIL -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" required />
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input name="Password" type="password" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-primary">
                Create User
            </button>

            <a asp-action="Index" class="btn btn-secondary ms-2">
                Cancel
            </a>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        const roleSelect = document.getElementById("roleSelect");
        const fullNameWrapper = document.getElementById("fullNameWrapper");
        const fullNameInput = document.getElementById("fullNameInput");
        const collegeWrapper = document.getElementById("collegeWrapper");
        const collegeSelect = document.getElementById("collegeSelect");
        const collegeValidation = document.getElementById("collegeValidation");

        function toggleFields() {
            const role = roleSelect.value;

            // FULL NAME
            if (role === "Admin" || role === "") {
                fullNameWrapper.style.display = "none";
                fullNameInput.value = "";
                fullNameInput.removeAttribute("required");
            } else {
                fullNameWrapper.style.display = "block";
                fullNameInput.setAttribute("required", "required");
            }

            // COLLEGE
            if (role === "Admin" || role === "") {
                collegeSelect.value = "";
                collegeSelect.removeAttribute("required");
                collegeWrapper.style.display = "none";
                collegeValidation.style.display = "none";
            } else {
                collegeWrapper.style.display = "block";
                collegeSelect.setAttribute("required", "required");
            }
        }

        document.querySelector("form").addEventListener("submit", function (e) {
            const role = roleSelect.value;

            if (role !== "Admin" && role !== "") {
                if (!collegeSelect.value) {
                    e.preventDefault();
                    collegeValidation.style.display = "block";
                }
            }
        });

        roleSelect.addEventListener("change", function () {
            collegeValidation.style.display = "none";
            toggleFields();
        });

        toggleFields();
    </script>
}