@model List<OnlineExamSystem.Models.User>

@{
    ViewData["Title"] = "User Management";
    var currentUserId = Context.Session.GetInt32("UserId");
    var colleges = ViewBag.Colleges as List<OnlineExamSystem.Models.College>;
    var selectedCollegeId = ViewBag.SelectedCollegeId as int?;
}

<h2 class="mb-4">User Management</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">

        <form method="get" class="row g-3 align-items-end">

            <div class="col-md-4">
                <label class="form-label">Search by Email</label>
                <input type="text"
                       name="searchEmail"
                       value="@ViewBag.SearchEmail"
                       class="form-control"
                       placeholder="Enter email" />
            </div>

            <div class="col-md-4">
                <label class="form-label">College</label>
                <select name="collegeId" class="form-select">
                    <option value="">All Colleges</option>
                    @if (colleges != null)
                    {
                        foreach (var college in colleges)
                        {
                            <option value="@college.Id"
                                    selected="@(selectedCollegeId == college.Id)">
                                @college.Name
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Apply Filters
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Reset
                </a>

                <a asp-action="Create" class="btn btn-success ms-auto">
                    + Create User
                </a>
            </div>

        </form>

    </div>
</div>

@if (Model.Any())
{
    <div class="card shadow-sm border-0">
        <div class="card-body">

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>College</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.Username</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge bg-secondary">
                                    @user.Role
                                </span>
                            </td>
                            <td>
                                @{
                                    if (user.CollegeId == null)
                                    {
                                        <span class="badge bg-dark">Global</span>
                                    }
                                    else
                                    {
                                        var collegeName = colleges?
                                        .FirstOrDefault(c => c.Id == user.CollegeId)?.Name;

                                        <span class="badge bg-info text-dark">
                                            @collegeName
                                        </span>
                                    }
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">

                                    <a asp-action="Edit"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-warning">
                                        Edit
                                    </a>

                                    @if (user.IsActive)
                                    {
                                        <a asp-action="ToggleStatus"
                                           asp-route-id="@user.Id"
                                           class="btn btn-sm btn-secondary">
                                            Disable
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="ToggleStatus"
                                           asp-route-id="@user.Id"
                                           class="btn btn-sm btn-success">
                                            Enable
                                        </a>
                                    }

                                    @if (user.Id != currentUserId)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-userid="@user.Id">
                                            Delete
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
}
else
{
    <div class="border rounded p-4 text-center text-muted mt-4">
        <h5>No users found</h5>
    </div>
}

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this user?
            </div>
            <div class="modal-footer">
                <form method="post" asp-action="DeleteConfirmed">
                    <input type="hidden" name="id" id="deleteUserId" />
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit"
                            class="btn btn-danger">
                        Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');

        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const userId = button.getAttribute('data-userid');
            document.getElementById('deleteUserId').value = userId;
        });
    </script>
}