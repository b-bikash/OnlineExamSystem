@model OnlineExamSystem.Models.ExamAttemptViewModel

@{
    ViewData["Title"] = "Exam Attempt";
    ViewData["HideNavbar"] = true;
    Layout = "_Layout";

    var designatedEndTime = Model.StartTime.AddMinutes(Model.DurationInMinutes);
    var actualEndTime = Model.ExamEndDateTime.HasValue && Model.ExamEndDateTime.Value < designatedEndTime
        ? Model.ExamEndDateTime.Value
        : designatedEndTime;

    int remainingSeconds = (int)(actualEndTime - DateTime.Now).TotalSeconds;
    if (remainingSeconds < 0) remainingSeconds = 0;
}

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f8;
    }

    .exam-header {
        background-color: #1e3a8a;
        color: white;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .student-info {
        background-color: #e5e7eb;
        padding: 10px 20px;
        font-weight: bold;
    }

    .exam-container {
        display: flex;
        padding: 20px;
    }

    .question-nav {
        width: 20%;
        background-color: white;
        padding: 15px;
        border-radius: 5px;
        margin-right: 20px;
    }

    /* 🔹 Anchor styled as button (Option 1 – recommended) */
    .nav-btn {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        width: 45px;
        height: 45px;
        margin: 5px;
        border-radius: 5px;
        background-color: #d1d5db;
        color: black;
        text-decoration: none;
        font-weight: bold;
        cursor: pointer;
    }

    .question-area {
        width: 80%;
        background-color: white;
        padding: 20px;
        border-radius: 5px;
    }

    .options label {
        display: block;
        margin: 10px 0;
        cursor: pointer;
    }

    .actions {
        margin-top: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* 🔹 Shared button-link style */
    .btn-link {
        padding: 10px 20px;
        border-radius: 5px;
        color: white;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .previous {
        background-color: #6b7280;
    }

    .save {
        background-color: #2563eb;
        border: none;
        color: white;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
    }

    .submit {
        background-color: #dc2626;
        margin-top: 20px;
        float: right;
        padding: 10px 25px;
        border-radius: 5px;
        color: white;
        border: none;
        cursor: pointer;
    }

    #fullscreen-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.95);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    #exam-content {
        display: none;
    }

    .fullscreen-btn {
        background-color: #2563eb;
        color: white;
        border: none;
        padding: 15px 30px;
        font-size: 1.2rem;
        border-radius: 5px;
        cursor: pointer;
        margin-top: 20px;
    }

    .fullscreen-btn:hover {
        background-color: #1d4ed8;
    }
</style>

<div id="fullscreen-overlay">
    <h2>Fullscreen Mode Required</h2>
    <p>This exam requires you to be in fullscreen mode to ensure a secure environment.</p>
    <button id="btn-enter-fullscreen" class="fullscreen-btn">Enter Fullscreen</button>
</div>

<div id="exam-content">
<div class="exam-header">
    <div>📘 @Model.ExamTitle</div>
    <div id="examTimer" style="font-size: 1.25rem; font-weight: bold; background: rgba(255,255,255,0.2); padding: 5px 15px; border-radius: 5px;">
        ⏱ @Model.DurationInMinutes:00
    </div>
    <div>Logout 🔒</div>
</div>

<div class="student-info">
    Attempt ID: @Model.AttemptId
</div>

<div class="exam-container">

    <!-- QUESTION NAVIGATION -->
    <div class="question-nav">
        <h4>Questions</h4>

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            <!-- ✅ Anchor styled as button (NO nested button) -->
            <a asp-action="Attempt"
               asp-route-attemptId="@Model.AttemptId"
               asp-route-questionIndex="@i"
               class="nav-btn">
                @(i + 1)
            </a>
        }
    </div>

    <!-- QUESTION AREA -->
    <div class="question-area">
        <h3>Question @(Model.CurrentQuestionIndex + 1)</h3>

        <p>@Model.Question.Text</p>

        <!-- SAVE ANSWER FORM -->
        <form asp-action="SaveAnswer" method="post">
            <input type="hidden" name="attemptId" value="@Model.AttemptId" />
            <input type="hidden" name="questionId" value="@Model.Question.Id" />
            <input type="hidden" name="questionIndex" value="@Model.CurrentQuestionIndex" />

            <div class="options">
                @foreach (var option in Model.Options)
                {
                    <label>
                        <input type="radio"
                               name="selectedOptionId"
                               value="@option.Id"
                               @(Model.SelectedOptionId == option.Id ? "checked" : "") />
                        @option.Text
                    </label>
                }
            </div>

            <div class="actions">
                @if (Model.CurrentQuestionIndex > 0)
                {
                    <!-- ✅ Previous navigation as anchor -->
                    <a asp-action="Attempt"
                       asp-route-attemptId="@Model.AttemptId"
                       asp-route-questionIndex="@(Model.CurrentQuestionIndex - 1)"
                       class="btn-link previous">
                        Previous
                    </a>
                }

                <!-- Save button stays a real submit button -->
                <button type="submit" class="save">Save</button>

                @if (Model.CurrentQuestionIndex < Model.TotalQuestions - 1)
                {
                    <!-- ✅ Next navigation as anchor -->
                    <a asp-action="Attempt"
                       asp-route-attemptId="@Model.AttemptId"
                       asp-route-questionIndex="@(Model.CurrentQuestionIndex + 1)"
                       class="btn-link save">
                        Next
                    </a>
                }
            </div>
        </form>

        <!-- SUBMIT EXAM -->
        <form method="post"
              action="/ExamAttempts/Submit"
              id="finalSubmitForm"
              onsubmit="return confirmSubmit();">

            @Html.AntiForgeryToken()

            <input type="hidden" name="attemptId" value="@Model.AttemptId" />

            <button type="submit" class="submit">
                Submit Exam
            </button>
        </form>

    </div>
</div>
</div> <!-- End exam-content -->

<script>
    // Fullscreen enforcement
    const overlay = document.getElementById('fullscreen-overlay');
    const examContent = document.getElementById('exam-content');
    const btnEnterFullscreen = document.getElementById('btn-enter-fullscreen');

    btnEnterFullscreen.addEventListener('click', () => {
        const elem = document.documentElement;
        if (elem.requestFullscreen) {
            elem.requestFullscreen();
        } else if (elem.mozRequestFullScreen) { // Firefox
            elem.mozRequestFullScreen();
        } else if (elem.webkitRequestFullscreen) { // Chrome, Safari and Opera
            elem.webkitRequestFullscreen();
        } else if (elem.msRequestFullscreen) { // IE/Edge
            elem.msRequestFullscreen();
        }
    });

    function checkFullscreen() {
        const isFullscreen = document.fullscreenElement ||
                             document.webkitIsFullScreen ||
                             document.mozFullScreen ||
                             document.msFullscreenElement;

        if (!isFullscreen) {
            overlay.style.display = 'flex';
            examContent.style.display = 'none';
        } else {
            overlay.style.display = 'none';
            examContent.style.display = 'block';
        }
    }

    document.addEventListener('fullscreenchange', checkFullscreen);
    document.addEventListener('webkitfullscreenchange', checkFullscreen);
    document.addEventListener('mozfullscreenchange', checkFullscreen);
    document.addEventListener('MSFullscreenChange', checkFullscreen);
    
    // Initial check
    checkFullscreen();

    // Exam Timer Logic for single-question view
    let remainingSeconds = @remainingSeconds;
    const timerElement = document.getElementById('examTimer');
    let isAutoSubmitting = false;

    function updateTimerDisplay() {
        if (remainingSeconds <= 0) {
            timerElement.innerText = "⏱ 00:00";
            if (!isAutoSubmitting) {
                isAutoSubmitting = true;
                alert("Time's up! Your exam will be automatically submitted.");
                document.getElementById('finalSubmitForm').submit();
            }
            return;
        }

        const minutes = Math.floor(remainingSeconds / 60);
        const seconds = remainingSeconds % 60;
        
        const minutesStr = minutes.toString().padStart(2, '0');
        const secondsStr = seconds.toString().padStart(2, '0');
        
        timerElement.innerText = `⏱ ${minutesStr}:${secondsStr}`;
        remainingSeconds--;
    }

    updateTimerDisplay();
    setInterval(updateTimerDisplay, 1000);

    function confirmSubmit() {
        if (isAutoSubmitting) return true; // bypass confirmation if auto submitting

        const totalQuestions = @Model.TotalQuestions;
        const answeredQuestions = document.querySelectorAll('input[type="radio"]:checked').length;

        if (answeredQuestions < totalQuestions) {
            return confirm(
                "You have not answered all the questions.\n\nAre you sure you want to submit?"
            );
        }

        return true;
    }
</script>

<script>
    // Prevent Multiple Tabs for the same exam attempt
    (function () {
        const attemptId = '@Model.AttemptId';
        const channelName = 'exam_attempt_' + attemptId;
        const bc = new BroadcastChannel(channelName);
        const pageId = Math.random().toString(36).substring(2);

        // Ping other tabs to see if they are open
        bc.postMessage({ type: 'ping', from: pageId });

        bc.onmessage = function (event) {
            if (event.data.type === 'ping') {
                // Another tab just opened this exam, tell them we are already here
                bc.postMessage({ type: 'pong', to: event.data.from });
            } else if (event.data.type === 'pong' && event.data.to === pageId) {
                // We received a pong meant for us, meaning another tab is already open
                alert("You cannot have this exam open in multiple tabs.");
                window.location.href = '/Exams';
            }
        };
    })();
</script>
