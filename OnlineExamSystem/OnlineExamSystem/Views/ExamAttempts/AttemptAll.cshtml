@model OnlineExamSystem.Models.ExamAttempt

@{
    ViewData["Title"] = "Attempt Exam";
    var questionIndex = 1;

    var designatedEndTime = Model.StartTime.AddMinutes(Model.Exam.DurationInMinutes);
    var actualEndTime = Model.Exam.EndDateTime.HasValue && Model.Exam.EndDateTime.Value < designatedEndTime
        ? Model.Exam.EndDateTime.Value
        : designatedEndTime;

    int remainingSeconds = (int)(actualEndTime - DateTime.Now).TotalSeconds;
    if (remainingSeconds < 0) remainingSeconds = 0;
}

<style>
    .question-sidebar {
        position: sticky;
        top: 90px;
    }

    .question-number {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid #ccc;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        margin-bottom: 10px;
        font-weight: 500;
        background-color: #fff;
    }

        .question-number.answered {
            background-color: #198754;
            color: #fff;
            border-color: #198754;
        }

        .question-number.unanswered {
            background-color: #e9ecef;
            color: #000;
        }

    .question-card {
        scroll-margin-top: 90px;
    }

    #fullscreen-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.95);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    #exam-content {
        display: none;
    }

    .fullscreen-btn {
        background-color: #2563eb;
        color: white;
        border: none;
        padding: 15px 30px;
        font-size: 1.2rem;
        border-radius: 5px;
        cursor: pointer;
        margin-top: 20px;
    }

    .fullscreen-btn:hover {
        background-color: #1d4ed8;
    }
</style>

<div id="fullscreen-overlay">
    <h2>Fullscreen Mode Required</h2>
    <p>This exam requires you to be in fullscreen mode to ensure a secure environment.</p>
    <button id="btn-enter-fullscreen" class="fullscreen-btn">Enter Fullscreen</button>
</div>

<div id="exam-content">
<div class="container-fluid my-4">
    <div class="row">

        <!-- LEFT SIDEBAR -->
        <div class="col-md-2 d-none d-md-block">
            <div class="question-sidebar">
                @for (int i = 1; i <= Model.Exam.Questions.Count; i++)
                {
                    <div class="question-number unanswered"
                         data-question="@i">
                        @i
                    </div>
                }
            </div>
        </div>

        <!-- MAIN CONTENT -->
        <div class="col-md-10">

            <!-- Exam Header -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h2 class="mb-0">@Model.Exam.Title</h2>
                        <div class="text-danger fw-bold fs-4 border rounded px-3 py-1 bg-light">
                            <i class="bi bi-clock-history me-2"></i><span id="examTimer">--:--</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Exam.Description))
                    {
                        <p class="text-muted mb-0">
                            @Model.Exam.Description
                        </p>
                    }
                </div>
            </div>

            <form method="post"
                  action="/ExamAttempts/SubmitAll"
                  id="examForm">

                @Html.AntiForgeryToken()
                <input type="hidden" name="attemptId" value="@Model.Id" />

                @{
                    questionIndex = 1;
                }

                @foreach (var question in Model.Exam.Questions)
                {
                    <div class="card mb-4 shadow-sm question-card"
                         id="question-@questionIndex"
                         data-question-index="@questionIndex">
                        <div class="card-body">

                            <div class="mb-3 fw-semibold">
                                Question @questionIndex
                            </div>

                            <div class="mb-3">
                                @question.Text
                            </div>

                            @foreach (var option in question.Options)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="answers[@question.Id]"
                                           value="@option.Id"
                                           data-question="@questionIndex"
                                           id="q@questionIndex_opt@option.Id"
                                           @(Model.StudentAnswers.Any(a =>
                                                                              a.QuestionId == question.Id &&
                                                                              a.SelectedOptionId == option.Id)
                                                                              ? "checked" : "") />

                                    <label class="form-check-label"
                                           for="q@questionIndex_opt@option.Id">
                                        @option.Text
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    questionIndex++;
                }

                <div class="text-end">
                    <button type="submit"
                            class="btn btn-danger px-4">
                        Submit Exam
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

</div>
</div> <!-- End exam-content -->

<!-- HIDDEN WEBCAM ELEMENTS -->
<video id="webcam-video" autoplay playsinline style="display: none;"></video>
<canvas id="webcam-canvas" style="display: none;"></canvas>

<!-- SUBMIT CONFIRM MODAL -->
<div class="modal fade"
     id="confirmSubmitModal"
     tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Submit Exam?</h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                You have not answered all the questions.<br />
                Are you sure you want to submit?
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button"
                        class="btn btn-danger"
                        id="confirmSubmitBtn">
                    Submit Anyway
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <!-- Bootstrap Icons for Timer -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <!-- Face-API.js -->
    <script src="~/lib/face-api/face-api.min.js"></script>

    <script>
        // Fullscreen enforcement
        const overlay = document.getElementById('fullscreen-overlay');
        const examContent = document.getElementById('exam-content');
        const btnEnterFullscreen = document.getElementById('btn-enter-fullscreen');

        btnEnterFullscreen.addEventListener('click', () => {
            const elem = document.documentElement;
            if (elem.requestFullscreen) {
                elem.requestFullscreen();
            } else if (elem.mozRequestFullScreen) { // Firefox
                elem.mozRequestFullScreen();
            } else if (elem.webkitRequestFullscreen) { // Chrome, Safari and Opera
                elem.webkitRequestFullscreen();
            } else if (elem.msRequestFullscreen) { // IE/Edge
                elem.msRequestFullscreen();
            }
        });

        function checkFullscreen() {
            const isFullscreen = document.fullscreenElement ||
                                 document.webkitIsFullScreen ||
                                 document.mozFullScreen ||
                                 document.msFullscreenElement;

            if (!isFullscreen) {
                overlay.style.display = 'flex';
                examContent.style.display = 'none';
            } else {
                overlay.style.display = 'none';
                examContent.style.display = 'block';
            }
        }

        document.addEventListener('fullscreenchange', checkFullscreen);
        document.addEventListener('webkitfullscreenchange', checkFullscreen);
        document.addEventListener('mozfullscreenchange', checkFullscreen);
        document.addEventListener('MSFullscreenChange', checkFullscreen);

        // Initial check
        checkFullscreen();

        // Webcam & Face AI Logic
        const video = document.getElementById('webcam-video');
        const canvas = document.getElementById('webcam-canvas');
        let modelsLoaded = false;

        async function initWebcamAndAI() {
            try {
                // Load AI Models
                await faceapi.nets.tinyFaceDetector.loadFromUri('/lib/face-api/models');
                modelsLoaded = true;
                console.log("Face-API models loaded successfully.");

                // Request Webcam
                const stream = await navigator.mediaDevices.getUserMedia({ video: true });
                video.srcObject = stream;
            } catch (err) {
                console.error("Error accessing webcam or loading models:", err);
                alert("This exam requires webcam access and AI initialization. Please allow camera permissions to continue.");
            }
        }

        initWebcamAndAI();

        const ATTEMPT_ID = '@Model.Id';
        const CAPTURE_INTERVAL_MS = 10000;

        async function captureAndUploadImage() {
            if (!video.srcObject || !modelsLoaded) return;

            let suspiciousFlag = false;
            let suspiciousReason = null;

            try {
                // 1. Run Face Detection
                const detections = await faceapi.detectAllFaces(video, new faceapi.TinyFaceDetectorOptions());
                
                if (detections.length === 0) {
                    suspiciousFlag = true;
                    suspiciousReason = "No face detected";
                } else if (detections.length > 1) {
                    suspiciousFlag = true;
                    suspiciousReason = "Multiple faces detected";
                }

                // 2. Capture Image
                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                
                const base64Image = canvas.toDataURL('image/jpeg', 0.8);

                // 3. Send to Backend
                fetch(`/ExamAttempts/CaptureImage?attemptId=${ATTEMPT_ID}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        Base64Image: base64Image,
                        SuspiciousFlag: suspiciousFlag,
                        SuspiciousReason: suspiciousReason
                    })
                })
                .catch(err => console.error("Error:", err));

            } catch(e) {
                console.error("Error during face detection:", e);
            }
        }

        setInterval(captureAndUploadImage, CAPTURE_INTERVAL_MS);

        // Exam Timer Logic
        let remainingSeconds = @remainingSeconds;
        const timerElement = document.getElementById('examTimer');
        let isSubmitting = false;

        function updateTimerDisplay() {
            if (remainingSeconds <= 0) {
                timerElement.innerText = "00:00";
                if (!isSubmitting) {
                    isSubmitting = true;
                    alert("Time's up! Your exam will be automatically submitted.");
                    document.getElementById("examForm").submit();
                }
                return;
            }

            const minutes = Math.floor(remainingSeconds / 60);
            const seconds = remainingSeconds % 60;
            
            const minutesStr = minutes.toString().padStart(2, '0');
            const secondsStr = seconds.toString().padStart(2, '0');
            
            timerElement.innerText = `${minutesStr}:${secondsStr}`;
            remainingSeconds--;
        }

        // Initialize and start timer
        updateTimerDisplay();
        const timerInterval = setInterval(updateTimerDisplay, 1000);

        // Prevent Multiple Tabs for the same exam attempt
        (function () {
            const attemptId = '@Model.Id';
            const channelName = 'exam_attempt_' + attemptId;
            const bc = new BroadcastChannel(channelName);
            const pageId = Math.random().toString(36).substring(2);

            // Ping other tabs to see if they are open
            bc.postMessage({ type: 'ping', from: pageId });

            bc.onmessage = function (event) {
                if (event.data.type === 'ping') {
                    // Another tab just opened this exam, tell them we are already here
                    bc.postMessage({ type: 'pong', to: event.data.from });
                } else if (event.data.type === 'pong' && event.data.to === pageId) {
                    // We received a pong meant for us, meaning another tab is already open
                    alert("You cannot have this exam open in multiple tabs.");
                    window.location.href = '/Exams';
                }
            };
        })();

        const form = document.getElementById("examForm");
        const modal = new bootstrap.Modal(
            document.getElementById("confirmSubmitModal")
        );

        // Scroll on sidebar click
        document.querySelectorAll(".question-number").forEach(q => {
            q.addEventListener("click", () => {
                const index = q.getAttribute("data-question");
                document.getElementById("question-" + index)
                    .scrollIntoView({ behavior: "smooth" });
            });
        });

        // Update answered state
        document.querySelectorAll("input[type='radio']").forEach(radio => {
            radio.addEventListener("change", () => {
                const index = radio.getAttribute("data-question");
                const badge = document.querySelector(
                    `.question-number[data-question='${index}']`
                );
                badge.classList.remove("unanswered");
                badge.classList.add("answered");
            });
        });

        // Submit validation
        form.addEventListener("submit", function (e) {
            const total = @Model.Exam.Questions.Count;
            const answered =
                document.querySelectorAll("input[type='radio']:checked").length;

            if (answered < total) {
                e.preventDefault();
                modal.show();
            }
        });

        document.getElementById("confirmSubmitBtn")
            .addEventListener("click", function () {
                modal.hide();
                form.submit();
            });
    </script>
}
