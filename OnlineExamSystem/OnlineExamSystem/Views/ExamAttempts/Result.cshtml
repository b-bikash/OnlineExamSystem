@model OnlineExamSystem.Models.ExamAttempt

@{
    ViewData["Title"] = "Exam Result";
}

<h2>Exam Result</h2>

<hr />

<div>
    <p><strong>Exam Title:</strong> @Model.Exam.Title</p>
    <p><strong>Start Time:</strong> @Model.StartTime</p>
    <p><strong>End Time:</strong> @Model.EndTime</p>
    <p><strong>Score:</strong> @Model.Score / @Model.Exam.TotalMarks</p>
</div>

<hr />

@* ========================================= *@
@* PROCTORING REPORT (TEACHER / ADMIN ONLY)  *@
@* ========================================= *@

@if (Context.Session.GetString("Role") == "Teacher" || Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "TeacherAdmin")
{
    var allLogs = Model.ExamProctorLogs?.OrderBy(l => l.CapturedAt).ToList() ?? new List<OnlineExamSystem.Models.ExamProctorLog>();
    var suspiciousLogs = allLogs.Where(l => l.SuspiciousFlag == true).ToList();
    
    <div class="card mb-4 border-danger">
        <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Proctoring Report</h5>
        </div>
        <div class="card-body">
            @if (suspiciousLogs.Any())
            {
                var noFaceCount = suspiciousLogs.Count(l => l.SuspiciousReason.Contains("No face"));
                var multipleFaceCount = suspiciousLogs.Count(l => l.SuspiciousReason.Contains("Multiple faces"));

                <div class="row text-center mt-3">
                        <div class="col-md-4 mb-3">
                            <div class="card bg-light border-warning h-100">
                                <div class="card-body">
                                    <h1 class="display-4 text-warning">@noFaceCount</h1>
                                    <p class="lead mb-0 text-muted">
                                        @(noFaceCount == 1 ? "Frame" : "Frames") with <br/><strong>No Face Detected</strong>
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card bg-light border-danger h-100">
                                <div class="card-body">
                                    <h1 class="display-4 text-danger">@multipleFaceCount</h1>
                                    <p class="lead mb-0 text-muted">
                                        @(multipleFaceCount == 1 ? "Frame" : "Frames") with <br/><strong>Multiple Faces Detected</strong>
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card bg-light border-primary h-100">
                                <div class="card-body">
                                    <h1 class="display-4 text-primary">@Model.FullScreenExitCount</h1>
                                    <p class="lead mb-0 text-muted">
                                        @(Model.FullScreenExitCount == 1 ? "Time" : "Times") Student <br/><strong>Exited Fullscreen</strong>
                                    </p>
                                </div>
                            </div>
                        </div>
                </div>
            }
            else
            {
                <div class="alert alert-success mb-0 text-center">
                    <i class="bi bi-check-circle-fill me-2"></i> No suspicious activity detected during this exam.
                </div>
            }
        </div>
    </div>
    <hr />
}

<h3>Detailed Analysis</h3>

@if (Model.Exam.Questions != null && Model.Exam.Questions.Any())
{
    int i = 1;
    foreach (var question in Model.Exam.Questions)
    {
        var studentAnswer = Model.StudentAnswers.FirstOrDefault(sa => sa.QuestionId == question.Id);
        var selectedOptionId = studentAnswer?.SelectedOptionId;
        var correctOption = question.Options.FirstOrDefault(o => o.IsCorrect);
        var isCorrect = selectedOptionId == correctOption?.Id;

        <div class="card mb-3">
            <div class="card-header @(isCorrect ? "bg-success text-white" : "bg-danger text-white")">
                <strong>Q@(i). @question.Text</strong>
                <span class="float-end">
                    @(isCorrect ? "Correct" : "Wrong") 
                    (@question.Marks Marks)
                </span>
            </div>
            <div class="card-body">
                <ul class="list-group">
                    @foreach (var option in question.Options)
                    {
                        var isSelected = option.Id == selectedOptionId;
                        var isOptionCorrect = option.IsCorrect;

                        string listClass = "list-group-item";
                        if (isOptionCorrect)
                        {
                            listClass += " list-group-item-success"; // Green for correct answer
                        }
                        else if (isSelected && !isOptionCorrect)
                        {
                            listClass += " list-group-item-danger"; // Red for wrong selection
                        }

                        <li class="@listClass">
                            @option.Text
                            @if (isSelected)
                            {
                                <span class="badge bg-primary float-end">Your Answer</span>
                            }
                            @if (isOptionCorrect)
                            {
                                <span class="badge bg-success float-end me-1">Correct Answer</span>
                            }
                        </li>
                    }
                </ul>
            </div>
        </div>
        i++;
    }
}
else
{
    <p>No questions found for this exam.</p>
}

<hr />

@if (Context.Session.GetString("Role") == "Teacher")
{
    <a asp-controller="Exams" asp-action="Results" asp-route-examId="@Model.ExamId" class="btn btn-primary">
        Back to Results
    </a>
}
else
{
    <a asp-controller="Exams" asp-action="Index" class="btn btn-primary">
        Back to Exams
    </a>
}
