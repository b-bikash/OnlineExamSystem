@model OnlineExamSystem.Models.Question

@{
    ViewData["Title"] = "Delete Question";
}

<!-- ================= MAIN CONTAINER ================= -->
<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0" style="width: 100%; max-width: 500px; border-radius: 12px;">
        <div class="card-body p-4 text-center">

            <!-- ================= HEADER ================= -->
            <h3 class="text-danger mb-3">Delete Question</h3>

            <!-- ================= WARNING TEXT ================= -->
            <p class="mb-3">
                Are you sure you want to delete this question?
            </p>

            <!-- ================= QUESTION PREVIEW ================= -->
            <div class="alert alert-warning">
                <strong>@Model.Text</strong>
            </div>

            <!-- ================= EXTRA WARNING ================= -->
            <p class="text-muted small mb-4">
                This action cannot be undone.
            </p>

            <!-- ================= FORM ================= -->
            <form asp-action="DeleteConfirmed" method="post">

                <!-- HIDDEN QUESTION ID -->
                <input type="hidden" asp-for="Id" />

                <!-- ACTION BUTTONS -->
                <div class="d-flex justify-content-between">

                    <!-- CANCEL -->
                    <a asp-action="Index"
                           asp-route-examId="@Model.ExamId"
                           class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <!-- DELETE -->
                    <button type="submit" class="btn btn-danger">
                        Yes, Delete
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>