@model OnlineExamSystem.Models.QuestionEditViewModel

@{
    ViewData["Title"] = "Edit Question";
    Layout = "_Layout";

    // ================= ENSURE 4 OPTION SLOTS =================
    var optionSlots = new List<OnlineExamSystem.Models.OptionEditItemViewModel>();
    optionSlots.AddRange(Model.Options);

    while (optionSlots.Count < 4)
    {
        optionSlots.Add(new OnlineExamSystem.Models.OptionEditItemViewModel
        {
            OptionId = 0,
            Text = string.Empty
        });
    }
}

<!-- ================= MAIN CONTAINER ================= -->
<div class="d-flex justify-content-center align-items-start" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 700px; border-radius: 12px;">
        <div class="card-body p-4">

            <!-- ================= HEADER ================= -->
            <div class="text-center mb-4">
                <h3 class="mb-1">Edit Question</h3>
                <small class="text-muted">Update question details</small>
            </div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- ================= HIDDEN IDS ================= -->
                <input type="hidden" asp-for="QuestionId" />
                <input type="hidden" asp-for="ExamId" />

                <!-- ================= VALIDATION ================= -->
                <div class="text-danger mb-3">
                    @Html.ValidationSummary(false)
                </div>

                <!-- ================= QUESTION TEXT ================= -->
                <div class="mb-3">
                    <label asp-for="QuestionText" class="form-label">Question</label>
                    <textarea asp-for="QuestionText"
                              class="form-control"
                              rows="3"
                              placeholder="Edit your question"></textarea>
                    <span asp-validation-for="QuestionText" class="text-danger"></span>
                </div>

                <!-- ================= IMAGE SECTION ================= -->
                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label">
                        Update Question Image (Optional)
                    </label>

                    <!-- SHOW EXISTING IMAGE -->
                    @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
                    {
                        <div class="mb-2 text-center">
                            <img src="~/uploads/questions/@Model.ExistingImageUrl"
                                 alt="Current Image"
                                 style="max-width: 200px; border-radius: 8px;" />
                        </div>
                    }

                    <input asp-for="ImageFile"
                           type="file"
                           class="form-control"
                           accept="image/*" />

                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <!-- ================= MARKS ================= -->
                <div class="mb-3">
                    <label class="form-label">Marks</label>
                    <input type="number"
                           name="Marks"
                           class="form-control"
                           min="0"
                           value="@Model.Marks"
                           placeholder="Enter marks"
                           required />
                    <small class="text-muted">
                        Enter marks for this question (0 or more).
                    </small>
                </div>

                <hr />

                <!-- ================= OPTIONS ================= -->
                <div class="mb-3">
                    <h5 class="mb-2">Options</h5>
                    <p class="text-muted small mb-3">
                        Edit options (2–4 allowed) and select the correct one.
                    </p>

                    @for (int i = 0; i < optionSlots.Count; i++)
                    {
                        <div class="border rounded p-3 mb-2">

                            <!-- OPTION ID (IMPORTANT FOR UPDATE) -->
                            <input type="hidden"
                                   name="Options[@i].OptionId"
                                   value="@optionSlots[i].OptionId" />

                            <!-- CORRECT OPTION RADIO -->
                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="radio"
                                       name="CorrectOptionId"
                                       value="@optionSlots[i].OptionId"
                                @(optionSlots[i].OptionId == Model.CorrectOptionId && optionSlots[i].OptionId != 0
                                                                           ? "checked"
                                                                           : "") />

                                <label class="form-check-label">
                                    Mark as Correct
                                </label>
                            </div>

                            <!-- OPTION TEXT -->
                            <input class="form-control"
                                   name="Options[@i].Text"
                                   value="@optionSlots[i].Text"
                                   placeholder="Option @(i + 1)" />

                        </div>
                    }
                </div>

                <!-- ================= ACTION BUTTONS ================= -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index"
                           asp-route-examId="@Model.ExamId"
                           class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-success">
                        Save Changes
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}