@model OnlineExamSystem.Models.QuestionCreateViewModel

@{
    ViewData["Title"] = "Create Question";
    Layout = "_Layout";
}

<!-- ================= MAIN CONTAINER ================= -->
<div class="d-flex justify-content-center align-items-start" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 700px; border-radius: 12px;">
        <div class="card-body p-4">

            <!-- ================= HEADER ================= -->
            <div class="text-center mb-4">
                <h3 class="mb-1">Create Question</h3>
                <small class="text-muted">Add a new question to the exam</small>
            </div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- ================= HIDDEN EXAM ID ================= -->
                <input type="hidden" asp-for="ExamId" />

                <!-- ================= VALIDATION SUMMARY ================= -->
                <div class="text-danger mb-3">
                    @Html.ValidationSummary(false)
                </div>

                <!-- ================= QUESTION TEXT ================= -->
                <div class="mb-3">
                    <label asp-for="QuestionText" class="form-label">Question</label>
                    <textarea asp-for="QuestionText"
                              class="form-control"
                              rows="3"
                              placeholder="Enter your question here"></textarea>
                    <span asp-validation-for="QuestionText" class="text-danger"></span>
                </div>

                <!-- ================= IMAGE UPLOAD ================= -->
                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label">
                        Question Image (Optional)
                    </label>
                    <input asp-for="ImageFile"
                           type="file"
                           class="form-control"
                           accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <!-- ================= MARKS ================= -->
                <div class="mb-3">
                    <label class="form-label">Marks</label>
                    <input type="number"
                           asp-for="Marks"
                           class="form-control"
                           min="0"
                           placeholder="Enter marks"
                           required />
                    <small class="text-muted">
                        Enter marks for this question (0 or more).
                    </small>
                </div>

                <hr />

                <!-- ================= OPTIONS SECTION ================= -->
                <div class="mb-3">
                    <h5 class="mb-2">Options</h5>
                    <p class="text-muted small mb-3">
                        Enter 2 to 4 options and select exactly one correct answer.
                    </p>

                    <!-- ================= OPTION 1 ================= -->
                    <div class="border rounded p-3 mb-2">
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="CorrectOptionIndex"
                                   value="0"
                                   required />
                            <label class="form-check-label">Mark as Correct</label>
                        </div>
                        <input name="Options[0]"
                               class="form-control"
                               placeholder="Option 1" />
                    </div>

                    <!-- ================= OPTION 2 ================= -->
                    <div class="border rounded p-3 mb-2">
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="CorrectOptionIndex"
                                   value="1"
                                   required />
                            <label class="form-check-label">Mark as Correct</label>
                        </div>
                        <input name="Options[1]"
                               class="form-control"
                               placeholder="Option 2" />
                    </div>

                    <!-- ================= OPTION 3 ================= -->
                    <div class="border rounded p-3 mb-2">
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="CorrectOptionIndex"
                                   value="2"
                                   required />
                            <label class="form-check-label">Mark as Correct</label>
                        </div>
                        <input name="Options[2]"
                               class="form-control"
                               placeholder="Option 3 (optional)" />
                    </div>

                    <!-- ================= OPTION 4 ================= -->
                    <div class="border rounded p-3 mb-2">
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="CorrectOptionIndex"
                                   value="3"
                                   required />
                            <label class="form-check-label">Mark as Correct</label>
                        </div>
                        <input name="Options[3]"
                               class="form-control"
                               placeholder="Option 4 (optional)" />
                    </div>

                    <!-- ================= CORRECT OPTION VALIDATION ================= -->
                    <span asp-validation-for="CorrectOptionIndex" class="text-danger"></span>
                </div>

                <!-- ================= ACTION BUTTONS ================= -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index"
                           asp-route-examId="@Model.ExamId"
                           class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-success">
                        Save Question
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}