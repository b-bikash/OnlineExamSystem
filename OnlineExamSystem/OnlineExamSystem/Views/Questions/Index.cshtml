<!-- ================= PAGE HEADER ================= -->
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">

    <!-- LEFT SIDE -->
    <div>
        <h2 class="mb-0">Questions</h2>

        @if (!string.IsNullOrEmpty(examTitle))
        {
            <small class="text-muted">
                Exam: <strong>@examTitle</strong>
            </small>
        }
    </div>

    <!-- RIGHT SIDE BUTTONS -->
    <div class="d-flex gap-2 flex-wrap">

        <a asp-controller="Exams"
               asp-action="Index"
               class="btn btn-outline-secondary">
            ← Back
        </a>

        <a asp-action="Create"
               asp-route-examId="@ViewBag.ExamId"
               class="btn btn-primary">
            Add Question
        </a>

        <a href="https://ai-mcq-generator-325582779572.us-west1.run.app/"
               target="_blank"
               class="btn btn-info text-white">
            Generate (AI)
        </a>

        

    </div>
</div>

<!-- ================= IMPORT SECTION (MOVED BELOW HEADER) ================= -->
<div class="card mb-3">
    <div class="card-body">
        <form asp-controller="QuestionImport"
              asp-action="Import"
              method="post"
              enctype="multipart/form-data"
              class="d-flex align-items-center gap-2 flex-wrap">

            <input type="hidden" name="examId" value="@ViewBag.ExamId" />

            <input type="file"
                   name="file"
                   class="form-control"
                   accept=".csv"
                   required />

            <button type="submit" class="btn btn-success">
                Import
            </button>
        </form>

        <small class="text-muted">
            Upload CSV to import questions. Click the “Generate (AI)” button to automatically create questions using AI, then download them as a CSV file.
        </small>
    </div>
</div>

<!-- ================= QUESTIONS TABLE ================= -->
<form id="bulkDeleteForm"
      asp-action="BulkDelete"
      asp-controller="Questions"
      method="post">
    
    <input type="hidden" name="examId" value="@ViewBag.ExamId" />
    <!-- NEW MULTI DELETE BUTTON -->
    <button type="submit"
            id="btnDeleteSelected"
            class="btn btn-danger"
            onclick="return confirmBulkDelete()">
        Delete Selected
    </button>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th style="width: 40px;">
                <input type="checkbox" id="selectAll" />
            </th>
            <th style="width: 80px;">S.No</th>
            <th style="width: 100px;">Image</th>
            <th>Question</th>
            <th style="width: 100px;">Marks</th>
            <th style="width: 160px;">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var q in Model)
        {
            <tr>
                <td>
                        <input type="checkbox" class="questionCheckbox" name="questionIds" value="@q.Id" />
                </td>
                <td>@serialNo</td>
                <td>
                    @if (!string.IsNullOrEmpty(q.ImageUrl))
                    {
                        <img src="~/uploads/questions/@q.ImageUrl" alt="Question Image" style="max-width: 80px; max-height: 80px;" />
                    }
                    else
                    {
                        <span class="text-muted text-center d-block">-</span>
                    }
                </td>
                <td>@q.Text</td>
                <td>@q.Marks</td>
                <td>
                    <a asp-action="Edit"
                       asp-route-id="@q.Id"
                       class="btn btn-sm btn-warning">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@q.Id"
                       class="btn btn-sm btn-danger ms-1">
                        Delete
                    </a>
                </td>
            </tr>

            serialNo++;
        }
    </tbody>
</table>
</form>

<script>
    // Select All Checkbox
    document.getElementById("selectAll").addEventListener("change", function () {
        let checkboxes = document.querySelectorAll(".questionCheckbox");
        checkboxes.forEach(cb => cb.checked = this.checked);
    });
</script>

<script>
    function confirmBulkDelete() {
        const selected = document.querySelectorAll(".questionCheckbox:checked");

        if (selected.length === 0) {
            alert("Please select at least one question.");
            return false;
        }

        return confirm("Are you sure you want to delete selected questions?");
    }
</script>