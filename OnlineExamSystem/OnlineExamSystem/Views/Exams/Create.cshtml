@model OnlineExamSystem.Models.Exam

@{
    ViewData["Title"] = "Create Exam";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 550px; border-radius: 12px;">
        <div class="card-body p-4">

            <h3 class="text-center mb-3">Create Exam</h3>
            <p class="text-center text-muted mb-4">Set up a new exam</p>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- TITLE -->
                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="Enter exam title" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- DESCRIPTION -->
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description"
                              class="form-control"
                              rows="3"
                              placeholder="Enter exam description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- DURATION -->
                <div class="mb-3">
                    <label asp-for="DurationInMinutes" class="form-label"></label>
                    <input asp-for="DurationInMinutes"
                           class="form-control"
                           type="number"
                           placeholder="Enter duration in minutes" />
                    <span asp-validation-for="DurationInMinutes" class="text-danger"></span>
                </div>

                <!-- SUBJECT -->
                <div class="mb-3">
                    <label asp-for="SubjectId" class="form-label">Subject</label>
                    <select asp-for="SubjectId"
                            asp-items="ViewBag.Subjects"
                            class="form-select">
                        <option value="">Select Subject</option>
                    </select>
                    <span asp-validation-for="SubjectId" class="text-danger"></span>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-success">
                        Create Exam
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}