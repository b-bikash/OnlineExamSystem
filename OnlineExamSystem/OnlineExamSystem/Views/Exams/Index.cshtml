@using Microsoft.AspNetCore.Http
@using OnlineExamSystem.Models
@using OnlineExamSystem.Models.ViewModels
@model object

@{
    ViewData["Title"] = "Exams";
    var role = Context.Session.GetString("Role");
    var now = OnlineExamSystem.Helpers.TimeHelper.GetLocalTime();
}

<h2>Exams</h2>

@* ================= STUDENT VIEW ================= *@
@if (role == "Student")
{
    var studentModel = Model as StudentExamsViewModel;

    if (!studentModel.IsProfileCompleted)
    {
        <div class="alert alert-warning">
            <strong>Complete your profile to access exams.</strong><br />
            <a asp-controller="Students" asp-action="Profile" class="alert-link">
                Complete Profile
            </a>
        </div>
    }
    else
    {
        <div class="accordion" id="studentExamAccordion">

            <!-- LIVE EXAMS -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#studentLiveExams">
                        Live Exams
                    </button>
                </h2>

                <div id="studentLiveExams" class="accordion-collapse collapse show">
                    <div class="accordion-body">

                        @if (!studentModel.LiveExams.Any())
                        {
                            <p>No live exams available.</p>
                        }
                        else
                        {
                            <table class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Description</th>
                                        <th>Subject</th>
                                        <th>Ends At</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var exam in studentModel.LiveExams)
                                    {
                                        <tr>
                                            <td>@exam.Title</td>
                                            <td>@exam.Description</td>
                                            <td>@exam.Subject?.Name</td>
                                            <td>@exam.EndDateTime</td>
                                            <td>
                                                <a asp-controller="ExamAttempts"
                                                   asp-action="CompatibilityTest"
                                                   asp-route-examId="@exam.Id"
                                                   class="btn btn-sm btn-success">
                                                    Start Exam
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <!-- UPCOMING EXAMS -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#studentUpcomingExams">
                        Upcoming Exams
                    </button>
                </h2>

                <div id="studentUpcomingExams" class="accordion-collapse collapse">
                    <div class="accordion-body">

                        @if (!studentModel.UpcomingExams.Any())
                        {
                            <p>No upcoming exams.</p>
                        }
                        else
                        {
                            <table class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Description</th>
                                        <th>Subject</th>
                                        <th>Starts At</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var exam in studentModel.UpcomingExams)
                                    {
                                        <tr>
                                            <td>@exam.Title</td>
                                            <td>@exam.Description</td>
                                            <td>@exam.Subject?.Name</td>
                                            <td>@exam.StartDateTime</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

            <!-- ATTEMPTED EXAMS -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#studentAttemptedExams">
                        Attempted Exams
                    </button>
                </h2>

                <div id="studentAttemptedExams" class="accordion-collapse collapse">
                    <div class="accordion-body">

                        @if (!studentModel.AttemptedExams.Any())
                        {
                            <p>No attempted exams yet.</p>
                        }
                        else
                        {
                            <table class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Description</th>
                                        <th>Subject</th>
                                        <th>Teacher</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in studentModel.AttemptedExams)
                                    {
                                        <tr>
                                            <td>@item.Exam.Title</td>
                                            <td>@item.Exam.Description</td>
                                            <td>@item.Exam.Subject?.Name</td>
                                            <td>@item.TeacherName</td>
                                            <td>
                                                @if (item.Exam.EndDateTime.HasValue && item.Exam.EndDateTime.Value > now)
                                                {
                                                    <button type="button" 
                                                            class="btn btn-sm btn-info" 
                                                            onclick="alert('Results will be available once the assigned time window for the exam is over.')">
                                                        View Result
                                                    </button>
                                                }
                                                else
                                                {
                                                    <a asp-controller="ExamAttempts"
                                                       asp-action="Result"
                                                       asp-route-attemptId="@item.Attempt.Id"
                                                       class="btn btn-sm btn-info">
                                                        View Result
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

        </div>
    }
}

@* ================= TEACHER VIEW ================= *@
@if (role == "Teacher" || role == "Admin" || role == "TeacherAdmin")
{
    @if (role == "Admin")
    {
        var colleges = ViewBag.Colleges as List<College>;
        var selectedCollegeId = ViewBag.SelectedCollegeId as int?;

        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">

                <form method="get" class="row g-3 align-items-end">

                    <div class="col-md-4">
                        <label class="form-label">College</label>
                        <select name="collegeId" class="form-select">
                            <option value="">All Colleges</option>
                            @if (colleges != null)
                            {
                                foreach (var college in colleges)
                                {
                                    <option value="@college.Id"
                                            selected="@(selectedCollegeId == college.Id)">
                                        @college.Name
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Apply Filter
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            Reset
                        </a>
                    </div>

                </form>

            </div>
        </div>
    }
    var exams = Model as IEnumerable<Exam> ?? Enumerable.Empty<Exam>();

    var unscheduled = exams
        .Where(e => !e.StartDateTime.HasValue)
        .OrderByDescending(e => e.CreatedAt)
        .ToList();

    var live = exams
        .Where(e => e.StartDateTime.HasValue && e.StartDateTime <= now && e.EndDateTime >= now)
        .OrderBy(e => e.EndDateTime)
        .ToList();

    var upcoming = exams
        .Where(e => e.StartDateTime.HasValue && e.StartDateTime > now)
        .OrderBy(e => e.StartDateTime)
        .ToList();

    var past = exams
        .Where(e => e.StartDateTime.HasValue && e.EndDateTime < now)
        .OrderByDescending(e => e.EndDateTime)
        .ToList();

    @* CREATE EXAM — TEACHER ONLY *@
    @if (role == "Teacher")
    {
        <a asp-action="Create" class="btn btn-primary mb-3">Create Exam</a>
    }

    <h4>Unscheduled Exams</h4>
    @if (!unscheduled.Any())
    {
        <p>No unscheduled exams.</p>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Subject</th>
                    <th>Total Marks</th>
                    @if (role == "Admin")
                    {
                        <th>Teacher</th>
                        <th>College</th>
                    }
                    @if (role == "TeacherAdmin")
                    {
                        <th>Teacher</th>
                    }
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exam in unscheduled)
                {
                    <tr>
                        <td>@exam.Title</td>
                        <td>@exam.Description</td>
                        <td>@exam.Subject?.Name</td>
                        <td>@exam.TotalMarks</td>

                        @if (role == "Admin" || role == "TeacherAdmin")
                        {
                            <td>@exam.CreatedByTeacher?.Name</td>
                            @if (role == "Admin")
                            {
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @exam.College?.Name
                                    </span>
                                </td>
                            }
                            
                        }

                        <td style="white-space: nowrap;">
                            <div class="btn-group" role="group">

                                <a asp-action="Edit"
                                       asp-route-id="@exam.Id"
                                       class="btn btn-sm btn-warning"
                                       title="Edit Exam">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-controller="Questions"
                                       asp-action="Index"
                                       asp-route-examId="@exam.Id"
                                       class="btn btn-sm btn-info"
                                       title="View Questions">
                                    <i class="bi bi-list"></i>
                                </a>

                                <a asp-action="Assign"
                                       asp-route-id="@exam.Id"
                                       class="btn btn-sm btn-secondary"
                                       title="Schedule Exam">
                                    <i class="bi bi-calendar"></i>
                                </a>

                                @if (role == "Admin" || role == "Teacher" || role == "TeacherAdmin")
                                {
                                    <a asp-action="Delete"
                                           asp-route-id="@exam.Id"
                                           class="btn btn-sm btn-danger"
                                           title="Delete Exam">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h4 class="mt-4 text-success">Live Exams</h4>
    @if (!live.Any())
    {
        <p>No live exams.</p>
    }
    else
    {
        <table class="table table-bordered border-success">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Subject</th>
                    <th>Total Marks</th>
                    @if (role == "Admin")
                    {
                        <th>Teacher</th>
                        <th>College</th>
                    }
                    @if (role == "TeacherAdmin")
                    {
                        <th>Teacher</th>
                    }
                    <th>Ends At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exam in live)
                {
                    <tr>
                        <td>@exam.Title</td>
                        <td>@exam.Description</td>
                        <td>@exam.Subject?.Name</td>
                        <td>@exam.TotalMarks</td>
                        @if (role == "Admin" || role == "TeacherAdmin")
                        {
                            <td>@exam.CreatedByTeacher?.Name</td>
                            @if (role == "Admin")
                            {
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @exam.College?.Name
                                    </span>
                                </td>
                            }
                            
                        }
                        <td>@exam.EndDateTime</td>
                        <td>
                            <a asp-action="Results"
                               asp-route-examId="@exam.Id"
                               class="btn btn-sm btn-dark">Results</a>
                            @if (role == "Admin")
                            {
                                <a asp-action="Delete"
                                   asp-route-id="@exam.Id"
                                   class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h4 class="mt-4 text-primary">Upcoming Exams</h4>
    @if (!upcoming.Any())
    {
        <p>No upcoming exams.</p>
    }
    else
    {
        <table class="table table-bordered border-primary">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Subject</th>
                    <th>Total Marks</th>
                    @if (role == "Admin")
                    {
                        <th>Teacher</th>
                        <th>College</th>
                    }
                    @if (role == "TeacherAdmin")
                    {
                        <th>Teacher</th>
                    }
                    <th>Starts At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exam in upcoming)
                {
                    <tr>
                        <td>@exam.Title</td>
                        <td>@exam.Description</td>
                        <td>@exam.Subject?.Name</td>
                        <td>@exam.TotalMarks</td>
                        @if (role == "Admin" || role == "TeacherAdmin")
                        {
                            <td>@exam.CreatedByTeacher?.Name</td>
                            @if (role == "Admin")
                            {
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @exam.College?.Name
                                    </span>
                                </td>
                            }
                            
                        }
                        <td>@exam.StartDateTime</td>
                        <td>
                            <a asp-action="Assign"
                               asp-route-id="@exam.Id"
                               asp-route-edit="true"
                               class="btn btn-sm btn-warning">Reschedule</a>
                            @if (role == "Admin" || role == "Teacher" || role == "TeacherAdmin")
                            {
                                <a asp-action="Delete"
                                   asp-route-id="@exam.Id"
                                   class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h4 class="mt-4 text-secondary">Past Exams</h4>
    @if (!past.Any())
    {
        <p>No past exams.</p>
    }
    else
    {
        <table class="table table-bordered border-secondary">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Subject</th>
                    <th>Total Marks</th>
                    @if (role == "Admin")
                    {
                        <th>Teacher</th>
                        <th>College</th>
                    }
                    @if (role == "TeacherAdmin")
                    {
                        <th>Teacher</th>
                    }
                    <th>Finished At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exam in past)
                {
                    <tr>
                        <td>@exam.Title</td>
                        <td>@exam.Description</td>
                        <td>@exam.Subject?.Name</td>
                        <td>@exam.TotalMarks</td>
                        @if (role == "Admin" || role == "TeacherAdmin")
                        {
                            <td>@exam.CreatedByTeacher?.Name</td>
                            @if (role == "Admin")
                            {
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @exam.College?.Name
                                    </span>
                                </td>
                            }
                            
                        }
                        <td>@exam.EndDateTime</td>
                        <td>
                            <a asp-action="Results"
                               asp-route-examId="@exam.Id"
                               class="btn btn-sm btn-dark">Results</a>
                            @if (role == "Admin")
                            {
                                <a asp-action="Delete"
                                   asp-route-id="@exam.Id"
                                   class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
