@model IEnumerable<OnlineExamSystem.Models.ExamAttempt>

@{
    ViewData["Title"] = "Exam Results";
}

<h2>Exam Results</h2>

<p>
    <strong>Exam:</strong> @ViewBag.ExamTitle
</p>

<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">
        No students have submitted this exam yet.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>S.No</th>
                <th>Student Name</th>
                <th>Roll Number</th>
                <th>Score</th>
                <th>Submitted At</th>
                <th>Proctoring Risk</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @{
                var sn = 1;
            }
            @foreach (var attempt in Model)
            {
                <tr>
                    <td>@sn</td>
                    <td>@attempt.Student?.Name</td>
                    <td>@attempt.Student?.RollNumber</td>
                    <td>@attempt.Score</td>
                    <td>@attempt.EndTime</td>
                    <td>
                        @{
                            var suspiciousCount = attempt.ExamProctorLogs?.Count(l => l.SuspiciousFlag == true) ?? 0;
                            var fsExitCount = attempt.FullScreenExitCount;
                            
                            // Let's say 1 full screen exit = 5 risk points, 1 suspicious frame = 1 risk point
                            var totalRiskScore = suspiciousCount + (fsExitCount * 5);

                            string badgeClass = "bg-success";
                            string riskText = "Low";

                            if (totalRiskScore >= 15)
                            {
                                badgeClass = "bg-danger";
                                riskText = "High";
                            }
                            else if (totalRiskScore >= 5)
                            {
                                badgeClass = "bg-warning text-dark";
                                riskText = "Medium";
                            }
                        }
                        <span class="badge @badgeClass">
                            @riskText Risk (@suspiciousCount frame flags, @fsExitCount exits)
                        </span>
                    </td>
                    <td>
                        <a asp-action="Result" asp-controller="ExamAttempts" asp-route-attemptId="@attempt.Id" class="btn btn-sm btn-info">
                            View Details
                        </a>
                    </td>
                </tr>
                sn++;
            }
        </tbody>
    </table>
}

<a asp-action="Index" asp-controller="Exams" class="btn btn-secondary">
    Back to Exams
</a>
