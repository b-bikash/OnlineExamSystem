@model OnlineExamSystem.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0" style="width: 100%; max-width: 420px; border-radius: 12px;">
        <div class="card-body p-4">

            <!-- HEADER -->
            <div class="text-center mb-4">
                <h3 class="mb-1">Forgot Password</h3>
                <small class="text-muted">Enter your email to reset password</small>
            </div>

            <!-- SUCCESS MESSAGE -->
            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success text-center py-2">
                    @ViewBag.Message
                </div>
            }

            <!-- FORM -->
            <form method="post">

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Enter your email"
                           required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">
                        Send Reset Link
                    </button>
                </div>

                <!-- BACK TO LOGIN -->
                <div class="text-center mt-3">
                    <a asp-action="Login" class="text-decoration-none small">
                        Back to Login
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}