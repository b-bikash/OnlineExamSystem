@model OnlineExamSystem.Models.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0" style="width: 100%; max-width: 420px; border-radius: 12px;">
        <div class="card-body p-4">

            <div class="text-center mb-4">
                <h3>Reset Password</h3>
                <small class="text-muted">Enter your new password</small>
            </div>

            <form method="post">

                <input type="hidden" asp-for="Token" />

                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" required />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-success">
                        Reset Password
                    </button>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="text-danger mt-2 text-center">
                        @Html.ValidationSummary()
                    </div>
                }

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}