@{
    ViewData["Title"] = "Login";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0" style="width: 100%; max-width: 420px; border-radius: 12px;">
        <div class="card-body p-4">

            <!-- HEADER -->
            <div class="text-center mb-4">
                <h3 class="mb-1">Welcome Back</h3>
                <small class="text-muted">Login to your account</small>
            </div>

            <!-- ERROR -->
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center py-2">
                    @ViewBag.Error
                </div>
            }

            <form method="post">

                <!-- USERNAME / EMAIL -->
                <div class="mb-3">
                    <label class="form-label">Email or Username</label>
                    <input type="text"
                           name="usernameOrEmail"
                           class="form-control"
                           placeholder="Enter email or username"
                           required
                           autofocus />
                </div>

                <!-- PASSWORD -->
                <div class="mb-1">
                    <label class="form-label">Password</label>
                    <input type="password"
                           name="password"
                           class="form-control"
                           id="passwordInput"
                           placeholder="Enter password"
                           required />
                </div>

                <!-- FORGOT PASSWORD LINK -->
                <div class="text-end mb-2">
                    <a asp-controller="Account"
                           asp-action="ForgotPassword"
                           class="small text-decoration-none">
                        Forgot Password?
                    </a>
                </div>

                <!-- SHOW PASSWORD -->
                <div class="mb-3 form-check">
                    <input type="checkbox"
                           class="form-check-input"
                           id="showPassword">
                    <label class="form-check-label small" for="showPassword">
                        Show Password
                    </label>
                </div>

                <!-- LOGIN BUTTON -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">
                        Login
                    </button>
                </div>

                <!-- REGISTER LINK -->
                <div class="text-center mt-3">
                    <span class="text-muted small">New user?</span>
                    <a asp-controller="Account"
                           asp-action="Register"
                           class="text-decoration-none fw-semibold ms-1">
                        Register here
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- SCRIPT -->
<script>
    document.getElementById('showPassword').addEventListener('change', function () {
        var passwordInput = document.getElementById('passwordInput');
        passwordInput.type = this.checked ? 'text' : 'password';
    });
</script>