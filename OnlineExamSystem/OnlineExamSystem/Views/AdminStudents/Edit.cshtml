@model OnlineExamSystem.Models.Student

@{
    ViewData["Title"] = "Edit Student";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 550px; border-radius: 12px;">
        <div class="card-body p-4">

            <h3 class="text-center mb-3">Edit Student</h3>
            <p class="text-center text-muted mb-4">Update student details</p>

            <form asp-action="Edit" method="post">

                <!-- HIDDEN -->
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="User.Id" />

                <!-- NAME -->
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Enter student name" />
                </div>

                <!-- EMAIL -->
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="User.Email"
                           class="form-control"
                           placeholder="Enter email" />
                </div>

                <!-- COURSE -->
                <div class="mb-3">
                    <label class="form-label">Course</label>
                    <select asp-for="CourseId" class="form-select">
                        <option value="">Select Course</option>
                        @foreach (var course in ViewBag.Courses)
                        {
                            <option value="@course.Id"
                                    selected="@(course.Id == Model.CourseId)">
                                @course.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- COLLEGE -->
                <div class="mb-3">
                    <label class="form-label">College</label>
                    <select asp-for="CollegeId" class="form-select">
                        <option value="">Select College</option>
                        @foreach (var college in ViewBag.Colleges)
                        {
                            <option value="@college.Id"
                                    selected="@(college.Id == Model.CollegeId)">
                                @college.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- ROLL NUMBER -->
                <div class="mb-3">
                    <label asp-for="RollNumber" class="form-label"></label>
                    <input asp-for="RollNumber"
                           class="form-control"
                           placeholder="Enter roll number" />
                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Save Changes
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>