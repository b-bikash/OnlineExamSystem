@model OnlineExamSystem.Models.ViewModels.CourseSubjectsViewModel

@{
    ViewData["Title"] = "Manage Subjects";
}

<div class="d-flex justify-content-center align-items-start" style="min-height: 80vh;">
    <div style="width: 100%; max-width: 700px;">

        <!-- HEADER -->
        <div class="mb-3 text-center">
            <h3 class="mb-0">Manage Subjects</h3>
            <small class="text-muted">
                Course: <strong>@Model.Course.Name</strong>
            </small>
        </div>

        <form asp-action="Subjects" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="courseId" value="@Model.Course.Id" />

            <!-- ================= ASSIGNED SUBJECTS ================= -->
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">

                    <h5 class="mb-3 text-success">Assigned Subjects</h5>

                    @if (Model.SelectedSubjectIds.Any())
                    {
                        @foreach (var subject in Model.AllSubjects
                                                    .Where(s => Model.SelectedSubjectIds.Contains(s.Id)))
                        {
                            <div class="form-check mb-2 p-2 rounded bg-light border border-success">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="selectedSubjectIds"
                                       value="@subject.Id"
                                       id="subject_@subject.Id"
                                       checked />

                                <label class="form-check-label fw-semibold"
                                       for="subject_@subject.Id">
                                    @subject.Name (@subject.Code)
                                </label>

                                <span class="badge bg-success ms-2">
                                    Assigned
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted fst-italic mb-0">
                            No subjects assigned yet.
                        </p>
                    }

                </div>
            </div>

            <!-- ================= AVAILABLE SUBJECTS ================= -->
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">

                    <h5 class="mb-3">Available Subjects</h5>

                    @foreach (var subject in Model.AllSubjects
                                            .Where(s => !Model.SelectedSubjectIds.Contains(s.Id)))
                    {
                        <div class="form-check mb-2 p-2 rounded border">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="selectedSubjectIds"
                                   value="@subject.Id"
                                   id="subject_@subject.Id" />

                            <label class="form-check-label"
                                   for="subject_@subject.Id">
                                @subject.Name (@subject.Code)
                            </label>
                        </div>
                    }

                </div>
            </div>

            <!-- ================= ACTIONS ================= -->
            <div class="d-flex justify-content-between mt-3">
                <a asp-action="Index"
                       class="btn btn-outline-secondary">
                    Back to Courses
                </a>

                <button type="submit" class="btn btn-primary">
                    Save Subjects
                </button>
            </div>

        </form>

    </div>
</div>