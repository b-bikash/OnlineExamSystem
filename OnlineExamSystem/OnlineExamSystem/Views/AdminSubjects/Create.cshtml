@model OnlineExamSystem.Models.Subject

@{
    ViewData["Title"] = "Add Subject";
    var role = Context.Session.GetString("Role");
    var colleges = ViewBag.Colleges as List<OnlineExamSystem.Models.College>;
}

<h2 class="mb-4">Add Subject</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <!-- 🔴 Validation Summary -->
            <div asp-validation-summary="All" class="text-danger"></div>

            <!-- 🏫 College Dropdown (Admin Only) -->
            @if (role == "Admin")
            {
                <div class="mb-3">
                    <label class="form-label">College</label>
                    <select asp-for="CollegeId" class="form-select" required>
                        <option value="">-- Select College --</option>
                        @if (colleges != null)
                        {
                            foreach (var college in colleges)
                            {
                                <option value="@college.Id">
                                    @college.Name
                                </option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CollegeId" class="text-danger"></span>
                </div>
            }

            <!-- 📘 Subject Name -->
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- 🏷 Subject Code -->
            <div class="mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                Save
            </button>

            <a asp-action="Index" class="btn btn-secondary ms-2">
                Cancel
            </a>

        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}