@model OnlineExamSystem.Models.Subject

@{
    ViewData["Title"] = "Add Subject";
    var role = Context.Session.GetString("Role");
    var colleges = ViewBag.Colleges as List<OnlineExamSystem.Models.College>;
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 500px; border-radius: 12px;">
        <div class="card-body p-4">

            <h3 class="text-center mb-3">Add Subject</h3>
            <p class="text-center text-muted mb-4">Create a new subject</p>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- VALIDATION -->
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- COLLEGE (Admin Only) -->
                @if (role == "Admin")
                {
                    <div class="mb-3">
                        <label class="form-label">College</label>
                        <select asp-for="CollegeId" class="form-select" required>
                            <option value="">Select College</option>
                            @if (colleges != null)
                            {
                                foreach (var college in colleges)
                                {
                                    <option value="@college.Id">
                                        @college.Name
                                    </option>
                                }
                            }
                        </select>
                        <span asp-validation-for="CollegeId" class="text-danger"></span>
                    </div>
                }

                <!-- SUBJECT NAME -->
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Enter subject name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- SUBJECT CODE -->
                <div class="mb-3">
                    <label asp-for="Code" class="form-label"></label>
                    <input asp-for="Code"
                           class="form-control"
                           placeholder="Enter subject code" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Save Subject
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}