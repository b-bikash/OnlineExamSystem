@model OnlineExamSystem.Models.Student

@{
    ViewData["Title"] = "My Profile";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 500px; border-radius: 12px;">
        <div class="card-body p-4">

            <h3 class="text-center mb-4">My Profile</h3>

            <!-- PROFILE DETAILS -->
            <div class="mb-3">
                <label class="text-muted small">Full Name</label>
                <div class="fw-semibold">@Model.Name</div>
            </div>

            <div class="mb-3">
                <label class="text-muted small">Course</label>
                <div class="fw-semibold">@Model.Course?.Name</div>
            </div>

            <div class="mb-3">
                <label class="text-muted small">College</label>
                <div class="fw-semibold">@Model.College?.Name</div>
            </div>

            <div class="mb-4">
                <label class="text-muted small">Roll Number</label>
                <div class="fw-semibold">@Model.RollNumber</div>
            </div>

            <!-- ACTION -->
            <a asp-action="EditProfile" class="btn btn-warning w-100">
                Edit Profile
            </a>

        </div>
    </div>
</div>