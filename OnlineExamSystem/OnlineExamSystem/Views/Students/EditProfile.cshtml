@model OnlineExamSystem.Models.ViewModels.StudentProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 500px; border-radius: 12px;">
        <div class="card-body p-4">

            <h3 class="text-center mb-3">Edit Profile</h3>
            <p class="text-center text-muted mb-4">Update your personal details</p>

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form asp-action="EditProfile" method="post">

                <!-- NAME -->
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter your name" />
                </div>

                <!-- COLLEGE -->
                <div class="mb-3">
                    <label class="form-label">College</label>

                    @if (ViewBag.IsAdmin == true)
                    {
                        <select asp-for="CollegeId"
                                asp-items="@(new SelectList(ViewBag.Colleges, "Id", "Name", Model.CollegeId))"
                                class="form-select"
                                id="collegeDropdown">
                        </select>
                    }
                    else
                    {
                        <input type="text"
                               class="form-control"
                               value="@ViewBag.CollegeName"
                               readonly />
                    }
                </div>

                <!-- COURSE -->
                <div class="mb-3">
                    <label class="form-label">Course</label>

                    <select asp-for="CourseId"
                            asp-items="@(new SelectList(ViewBag.Courses, "Id", "Name", Model.CourseId))"
                            class="form-select"
                            id="courseDropdown">

                        <option value="">Select Course</option>

                    </select>
                </div>

                <!-- ROLL NUMBER -->
                <div class="mb-3">
                    <label class="form-label">Roll Number</label>
                    <input asp-for="RollNumber" class="form-control" placeholder="Enter roll number" />
                    <span asp-validation-for="RollNumber" class="text-danger"></span>
                </div>

                <!-- BUTTON -->
                <button type="submit" class="btn btn-primary w-100 mt-2">
                    Save Profile
                </button>

            </form>
        </div>
    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        $("#collegeDropdown").change(function () {

            var collegeId = $(this).val();

            $.get("/AdminStudent/GetCoursesByCollege",
                { collegeId: collegeId },
                function (data) {

                    var courseDropdown = $("#courseDropdown");
                    courseDropdown.empty();

                    courseDropdown.append('<option value="">Select Course</option>');

                    $.each(data, function (i, course) {
                        courseDropdown.append(
                            `<option value="${course.id}">${course.name}</option>`
                        );
                    });
                });
        });
    </script>
}